# PromotionAI 开发环境配置

## 环境变量配置 (.env)

```env
# 应用配置
NODE_ENV=development
APP_NAME=PromotionAI
APP_VERSION=1.0.0
APP_PORT=3000
APP_HOST=localhost

# 数据库配置
DB_HOST=localhost
DB_PORT=5432
DB_NAME=promotionai_dev
DB_USER=dev_user
DB_PASSWORD=dev_password
DB_SSL=false
DB_POOL_MIN=2
DB_POOL_MAX=10

# Redis配置
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_TTL=86400

# MongoDB配置
MONGODB_URI=mongodb://localhost:27017/promotionai_logs
MONGODB_OPTIONS={"useNewUrlParser": true, "useUnifiedTopology": true}

# AI服务配置
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-4-turbo
OLLAMA_MODEL=llama3:70b
AI_TEMPERATURE=0.7
AI_MAX_TOKENS=2000

# 安全配置
JWT_SECRET=your_development_jwt_secret_key_here
JWT_EXPIRES_IN=24h
ENCRYPTION_KEY=your_development_encryption_key_here_32chars

# 限流配置
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# 监控配置
PROMETHEUS_ENABLED=true
GRAFANA_URL=http://localhost:3000
LOKI_URL=http://localhost:3100

# 外部API配置
CONTENT_SECURITY_API_KEY=your_content_security_api_key
SMS_SERVICE_API_KEY=your_sms_service_api_key
EMAIL_SERVICE_API_KEY=your_email_service_api_key

# 第三方平台API (示例)
DOUYIN_APP_ID=your_douyin_app_id
DOUYIN_APP_SECRET=your_douyin_app_secret
XIAOHONGSHU_APP_ID=your_xiaohongshu_app_id
XIAOHONGSHU_APP_SECRET=your_xiaohongshu_app_secret
WECHAT_APP_ID=your_wechat_app_id
WECHAT_APP_SECRET=your_wechat_app_secret

# CDN配置
CDN_BASE_URL=https://cdn.yourdomain.com
CDN_PROVIDER=aliyun
CDN_AK=your_cdn_access_key
CDN_SK=your_cdn_secret_key

# 钉钉机器人配置 (开发环境)
DINGTALK_WEBHOOK_DEV=https://oapi.dingtalk.com/robot/send?access_token=dev_webhook_token
DINGTALK_SECRET_DEV=dev_secret_key

# 日志配置
LOG_LEVEL=debug
LOG_FORMAT=json
LOG_FILE_SIZE=100M
LOG_RETENTION_DAYS=7

# 测试配置
TEST_DB_NAME=promotionai_test
TEST_REDIS_DB=1
TEST_MONGODB_URI=mongodb://localhost:27017/promotionai_test

# 安全配置
SECURITY_SCAN_ENABLED=false
COMPLIANCE_CHECK_ENABLED=true
DATA_MASKING_ENABLED=true
AUDIT_LOG_ENABLED=true

# 性能配置
CACHE_TTL_SHORT=300
CACHE_TTL_MEDIUM=1800
CACHE_TTL_LONG=3600
CONNECTION_TIMEOUT=10000
REQUEST_TIMEOUT=30000