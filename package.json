{
  "name": "promotionai",
  "version": "1.0.0",
  "description": "AI驱动的智能内容营销平台，专注于财经/健康领域的资讯采集、智能处理、多渠道分发和效果追踪",
  "main": "index.js",
  "scripts": {
    "start": "node index.js",
    "start:collector": "cd src/collector && npm start",
    "start:ai-processor": "cd src/ai-processor && npm start",
    "start:publisher": "cd src/publisher && npm start",
    "start:tracker": "cd src/tracker && npm start",
    "start:api-gateway": "cd src/api-gateway && npm start",
    "dev": "concurrently \"npm run start:collector\" \"npm run start:ai-processor\" \"npm run start:publisher\" \"npm run start:tracker\" \"npm run start:api-gateway\"",
    "test": "jest",
    "test:connectivity": "node scripts/test-connectivity.js",
    "migrate": "node scripts/simple-migrate.js",
    "stop": "pkill -f promotionai || echo 'No processes to kill'",
    "restart": "npm run stop && npm run dev",
    "logs": "tail -f logs/app.log",
    "status": "pm2 status || echo 'PM2 not installed'"
  },
  "keywords": [
    "ai",
    "marketing",
    "content",
    "promotion",
    "finance",
    "health",
    "automation"
  ],
  "author": "PromotionAI Team",
  "license": "MIT",
  "dependencies": {
    "axios": "^1.14.0",
    "dotenv": "^16.6.1",
    "moment": "^2.30.1",
    "node-cron": "^3.0.2",
    "pg": "^8.20.0",
    "redis": "^4.7.1",
    "uuid": "^9.0.1",
    "winston": "^3.19.0"
  },
  "devDependencies": {
    "concurrently": "^8.2.2",
    "eslint": "^8.52.0",
    "jest": "^29.7.0",
    "nodemon": "^3.0.1",
    "prettier": "^3.0.3"
  }
}