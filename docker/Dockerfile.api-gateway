# docker/Dockerfile.api-gateway
FROM node:18-alpine

WORKDIR /app

# 复制api-gateway的package文件
COPY src/api-gateway/package.json ./src/api-gateway/package.json

# 安装api-gateway依赖
RUN cd src/api-gateway && npm install --production

# 复制应用代码
COPY src/api-gateway/ ./src/api-gateway/
COPY config/ ./config/

# 创建日志目录
RUN mkdir -p logs

EXPOSE 3000

CMD ["sh", "-c", "cd src/api-gateway && npm start"]