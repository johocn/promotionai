# PromotionAI 环境配置文件
# 请复制此文件为 .env 并填入实际值

# 应用配置
NODE_ENV=development
PORT=3000

# 数据库配置
DB_HOST=localhost
DB_PORT=5432
DB_USER=app_user
DB_PASSWORD=secure_password
DB_NAME=promotionai_db
DB_SSL=false
DB_POOL_MIN=2
DB_POOL_MAX=10

# Redis配置
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_TTL=86400

# MongoDB配置
MONGODB_URI=mongodb://localhost:27017/promotionai

# AI服务配置
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-4-turbo
OLLAMA_URL=http://localhost:11434

# 消息队列配置
RABBITMQ_URL=amqp://localhost:5672
RABBITMQ_USERNAME=guest
RABMQ_PASSWORD=guest

# 安全配置
JWT_SECRET=your_jwt_secret_key_here
ENCRYPTION_KEY=your_32_char_encryption_key_here
SESSION_SECRET=your_session_secret_here

# 监控配置
PROMETHEUS_ENABLED=true
GRAFANA_URL=http://localhost:3000
PROMETHEUS_METRICS_ENDPOINT=/metrics

# API配置
API_RATE_LIMIT=100
API_RATE_WINDOW_MS=900000

# 采集服务配置
COLLECTOR_INTERVAL_MINUTES=30
MAX_CONCURRENT_REQUESTS=5

# AI处理配置
AI_TEMPERATURE=0.7
AI_MAX_TOKENS=2000

# 分发服务配置
PUBLISH_DELAY_SECONDS=5
MAX_PUBLISH_RETRIES=3

# 追踪服务配置
TRACKING_DOMAIN=track.yourdomain.com
SHORT_LINK_BASE_URL=https://yourdomain.com/s

# CDN配置
CDN_BASE_URL=https://cdn.yourdomain.com